DATABASE_URL=postgresql://purrsona:purrsona@localhost:5432/purrsona
# "disable" for local dev, "require" for RDS/managed Postgres in production.
DATABASE_SSL_MODE=disable
RATE_LIMIT_PER_MINUTE=60
JWT_SECRET=dev-secret-key
JWT_EXPIRY_HOURS=24
BOOTSTRAP_ADMIN_EMAIL=admin@purrsona.local

# Comma-separated list of allowed frontend origins for CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# S3 / S3-compatible image storage.
# Local dev (MinIO): set S3_ENDPOINT + static credentials as below.
# Production (real AWS S3): leave S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY
# unset so boto3 uses the ECS task's IAM role, and set S3_REGION instead.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=purrsona-images
# Optional: override the public URL used to build photo links, e.g. a
# CloudFront domain. Defaults to S3_ENDPOINT locally, or the S3 bucket's
# virtual-hosted-style URL in production.
S3_PUBLIC_BASE_URL=

MAX_IMAGE_SIZE_MB=10
BLUR_RADIUS_METERS=200
